# .env
# WHICH KANATA ADDRESS/PORT for messages
export KANATA_BIND_ADDRESS="127.0.0.1"
export KANATA_BIND_PORT=5829

# macos can only run kanata as root; we need to pass in a regular username to spawn sub-processes as.
export KANATA_USER=`whoami`
export KANATA_CONFIG_HOME=`pwd`

# which device(s) to intercept
export LINUX_DEV="/dev/input/by-id/usb-ZSA_Technology_Labs_ErgoDox_EZ-event-kbd:/dev/input/by-id/usb-ZSA_Technology_Labs_ErgoDox_EZ-event-if02"
# can kanata launch external commands
export DANGER_ENABLE_CMD=YES

# which keyboard layout/layers to use
export LAYOUTS_FILENAME="layout-42-key.kbd"

# lisp command to include sequence kbd file(s); can be multiple lines
export INCLUDE_SEQUENCES="
(include ../local/user_defined/hotkeys.kbd)
"

# lisp command to include macro kbd file(s); can be multiple lines
export INCLUDE_MACROS="(include ../local/user_defined/macros.kbd)"

# lisp command to include chord kbd file(s); can be multiple lines
export INCLUDE_CHORDS="
;; (include ../local/user_defined/chords.kbd)
"

