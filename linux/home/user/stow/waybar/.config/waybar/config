[
  {
    "id": "bar-bottom",
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "ipc": true,
    //	Choose the order of the modules
    "modules-left": [
      "sway/workspaces",
      "hyprland/workspaces"
    ],
    "modules-center": [
      "mpris"
    ],
    "modules-right": [
      "custom/wl-gammarelay-temperature",
      "custom/wl-gammarelay-brightness",
      "custom/wl-gammarelay-gamma",
      "cpu",
      "memory",
      "custom/temperature",
      "backlight",
      // "wireplumber",
      "pulseaudio",
      "battery",
      "idle_inhibitor",
      "clock",
      "custom/notification",
      "network",
      "tray"
    ],
    // Modules configuration
    "sway/workspaces": {
      "disable-scroll": false,
      "all-outputs": false,
      "format": "{name}",
      "format-icons": {
        "urgent": "<span color='#e85c5c'>´ü¬</span>",
        "focused": "<span color='#8af0f0'>´ćĺ</span>",
        "default": "<span color='#b8b8b8'>´äĹ</span>"
      }
    },
    "hyprland/workspaces": {
      "disable-scroll": false,
      "all-outputs": false,
      "format": "{name}",
      "format-icons": {
        "urgent": "<span color='#e85c5c'>´ü¬</span>",
        "focused": "<span color='#8af0f0'>´ćĺ</span>",
        "default": "<span color='#b8b8b8'>´äĹ</span>"
      }
    },
    "sway/mode": {},
    "hyprland/submap": {},
    "backlight": {
      "device": "acpi_video1",
      "format": "{icon} {percent}%",
      "format-icons": [
        "­čöů",
        "­čöć"
      ]
    },
    "wireplumber": {
      "format": "{icon} {volume}%",
      "format-muted": "ˇ░Łč",
      "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
      "on-click-right": "pavucontrol",
      "format-icons": [
        "´ÇŽ",
        "´Çž",
        "´ÇĘ"
      ]
    },
    "battery": {
      "states": {
        "good": 95,
        "warning": 20,
        "critical": 10
      },
      "format-alt": "{power}W",
      "format-time": "{H}h{M}",
      "format": "<span color='#e88939'>{icon}</span>{capacity}%<span color='#e99949'>{time}</span>@{power}W",
      "format-charging": "<span color='#e88939'>{icon}C</span>{capacity}%{time}",
      "format-plugged": "<span color='#e88939'>{icon}´çŽ</span>{capacity}%{time}",
      "format-good": "<span color='#e88939'>{icon}</span>{capacity}%<span color='#e99949'>{time}</span>@{power}W",
      "format-discharging": "<span color='#e88939'>{icon}</span>{capacity}%<span color='#e99949'>{time}</span>@{power}W",
      "format-icons": [
        "´ëä",
        "´ëâ",
        "´ëé",
        "´ëü",
        "´ëÇ"
      ],
      "on-click-right": "sudo /root/.local/bin/system/battery_conservation_mode.sh 1",
      "on-click-middle": "sudo /root/.local/bin/system/battery_conservation_mode.sh 0",
      "max-length": 18,
      "min-length": 9
    },
    "clock": {
      "interval": 1,
      "format": "<span color='#cde9f0'>{:%F %a %T}</span>",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "calendar": {
        "mode": "year",
        "mode-mon-col": 3,
        "weeks-pos": "right",
        "on-submap-change": "noop",
        "format": {
          "months": "<span color='#ffead3'><b>{}</b></span>",
          "days": "<span color='#ecc6d9'><b>{}</b></span>",
          "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
          "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
          "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
        }
      },
      "on-click-right": "date '+%F %H:%M:%S' | wl-copy -n"
    },
    "cpu": {
      "interval": 5,
      "format": "<span color='#eb8a60'>´ĺ╝{usage}%({load})</span>", // Icon: microchip
      "states": {
        "warning": 70,
        "critical": 90
      }
    },
    "idle_inhibitor": {
      "format": "<span color='#589df6'>{icon}</span>",
      "format-icons": {
        "activated": "´â┤",
        "deactivated": "´ü░"
      },
      //"on-click-right": "swaylock -eFfki -c 000000"
      "on-click-right": "swaylock -f -c 000000"
    },
    "memory": {
      "format": "ţëŽ{used:0.1f}G",
      "tooltip": false
    },
    "network": {
      "format-wifi": "<span color='#589df6'>´çź</span> <span color='gray'>{signalStrength}%</span>",
      "format-ethernet": "´×ľ",
      "format-linked": "(no addr) ´×ľ",
      "format-disconnected": "´çź ´äž",
      "format-alt": "<span color='gray'>{essid}</span> <span color='green'>ÔČç</span>{bandwidthDownBits} <span color='green'>ÔČć</span>{bandwidthUpBits}",
      "interval": 60,
      "tooltip-format": "{ifname} {essid} ´éę {ipaddr}/{cidr}"
    },
    "pulseaudio": {
      "format": "{icon}{volume}% {format_source}",
      "format-muted": "ˇ░Łč{format_source}",
      "format-bluetooth": "{icon}´Őö{volume}% {format_source}",
      "format-bluetooth-muted": "ˇ░Łč´Őö{format_source}",
      "format-source": "´ä░{volume}%",
      "format-source-muted": "´ä▒",
      "format-icons": {
        "headphones": "´Çą",
        "handsfree": "´ľÉ",
        "headset": "´ľÉ",
        "phone": "´éĽ",
        "portable": "´éĽ",
        "car": "´ć╣",
        "default": [
          "´ÇŽ",
          "´Çž",
          "´ÇĘ"
        ]
      },
      "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
      "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
      "on-click-middle": "pavucontrol"
      //"scroll-step": 1, // %, can be a float
      //"on-scroll-down": "pactl set-sink-volume   @DEFAULT_SINK@  +1%",
      //"on-scroll-up": "pactl set-sink-volume   @DEFAULT_SINK@  -10%"
    },
    "custom/temperature": {
      "exec": "~/.config/waybar/scripts/temperature.sh",
      "interval": 5,
      "format": "{}",
      "return-type": "json",
      "tooltip": true
    },
    "tray": {
      "icon-size": 18,
      "spacing": 5
    },
    // see https://github.com/MaxVerevkin/wl-gammarelay-rs
    "custom/wl-gammarelay-temperature": {
      "format": "´ćć{}",
      "exec": "wl-gammarelay-rs watch {t}",
      "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +100",
      "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -100",
      "on-click": "busctl --user set-property rs.wl-gammarelay / rs.wl.gammarelay Temperature q 6500",
      "on-click-right": "busctl --user set-property rs.wl-gammarelay / rs.wl.gammarelay Temperature q 6500"
    },
    "custom/wl-gammarelay-brightness": {
      "format": "<span color='#eb8a60'>´âź{}%</span>",
      "exec": "wl-gammarelay-rs watch {bp}",
      "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateBrightness d +0.05",
      "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateBrightness d -0.05",
      "on-click": "busctl --user set-property rs.wl-gammarelay / rs.wl.gammarelay Brightness d 0.6",
      "on-click-right": "busctl --user set-property rs.wl-gammarelay / rs.wl.gammarelay Brightness d 1.0"
    },
    "custom/wl-gammarelay-gamma": {
      "format": "╬│{}%",
      "exec": "wl-gammarelay-rs watch {g}",
      "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateGamma d +0.02",
      "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateGamma d -0.02"
    },
    "mpris": {
      "format": "{player_icon}{title} - {artist}",
      "format-paused": "{status_icon} <i>{title} - {artist}</i>",
      "ignored-players": [
        "firefox",
        "chromium",
        "chrome",
        "brave"
      ],
      "player-icons": {
        "default": "ÔľÂ",
        "spotify": "´ć╝",
        "mpv": "­čÄÁ"
      },
      "status-icons": {
        "paused": "ÔĆŞ"
      },
      "max-length": 50
    },
    "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
        "notification": "´éó<span foreground='red'><sup>´Ĺä</sup></span>",
        "none": "´éó",
        "dnd-notification": "´çĚ<span foreground='red'><sup>´Ĺä</sup></span>",
        "dnd-none": "´çĚ",
        "inhibited-notification": "´éó<span foreground='red'><sup>´Ĺä</sup></span>",
        "inhibited-none": "´éó",
        "dnd-inhibited-notification": "´çĚ<span foreground='red'><sup>´Ĺä</sup></span>",
        "dnd-inhibited-none": "´çĚ"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
    }
  },
  {
    "id": "bar-menu-mode",
    "layer": "top",
    "position": "bottom",
    "exclusive": false,
    "margin-bottom": 40,
    "ipc": true,
    "modules-center": [
      "sway/mode",
      "hyprland/submap"
    ],
    "sway/mode": {
      "format": "<span font_weight=\"bold\">{}</span>"
    },
    "hyprland/submap": {
      "format": "<span font_weight=\"bold\">{}</span>"
    }
  }
]
