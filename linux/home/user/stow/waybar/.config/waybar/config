[
  {
    "id": "bar-bottom-left",
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "ipc": true,
    "output": "DVI-D-1",
    //	Choose the order of the modules
    "modules-left": [
      "sway/workspaces",
      "hyprland/workspaces"
    ],
    "modules-right": [
      "backlight",
      // "wireplumber",
      "pulseaudio",
      "battery",
      "idle_inhibitor",
      "clock",
      "custom/notification",
      "network",
      "tray"
    ],
    "include": ["./modules.json"]
  },
  {
    "id": "bar-bottom-mid",
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "ipc": true,
    "output": "DP-1",
    //	Choose the order of the modules
    "modules-left": [
      "sway/workspaces",
      "hyprland/workspaces"
    ],
    "modules-center": [
      "mpris"
    ],
    "modules-right": [
      "custom/wl-gammarelay-temperature",
      "custom/wl-gammarelay-brightness",
      "custom/wl-gammarelay-gamma",
      "cpu",
      "memory",
      "custom/temperature",
      "backlight",
      // "wireplumber",
      "pulseaudio",
      "battery",
      "idle_inhibitor",
      "clock",
      "custom/notification",
      "network",
      "tray"
    ],
    "include": ["./modules.json"]
  },
  {
    "id": "bar-bottom-right",
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "ipc": true,
    "output": "HDMI-A-1",
    //	Choose the order of the modules
    "modules-left": [
      "sway/workspaces",
      "hyprland/workspaces"
    ],
    "modules-right": [
      "backlight",
      // "wireplumber",
      "pulseaudio",
      "battery",
      "idle_inhibitor",
      "clock",
      "custom/notification",
      "network",
      "tray"
    ],
    "include": ["./modules.json"]
  },
  {
    "id": "bar-menu-mode",
    "layer": "top",
    "position": "bottom",
    "exclusive": false,
    "margin-bottom": 40,
    "ipc": true,
    "modules-center": [
      "sway/mode",
      "hyprland/submap"
    ],
    "sway/mode": {
      "format": "<span font_weight=\"bold\">{}</span>"
    },
    "hyprland/submap": {
      "format": "<span font_weight=\"bold\">{}</span>"
    },
    "include": ["./modules.json"]
  }
]
